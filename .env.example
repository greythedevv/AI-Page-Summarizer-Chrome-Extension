# ─────────────────────────────────────────────────────────────
#  PageMind — Environment Variables
#  Copy this file to .env and fill in your real values.
#  .env is gitignored and MUST NEVER be committed.
# ─────────────────────────────────────────────────────────────

# AI provider to use: openai | anthropic | gemini
PAGEMIND_PROVIDER=anthropic

# Your API key for the chosen provider
# Anthropic  → https://console.anthropic.com
# OpenAI     → https://platform.openai.com/api-keys
# Gemini     → https://aistudio.google.com/app/apikey
PAGEMIND_API_KEY=your-api-key-here

# (Optional) Override the default model for your provider
# Anthropic default : claude-haiku-4-5
# OpenAI default    : gpt-4o-mini
# Gemini default    : gemini-2.0-flash
PAGEMIND_MODEL=
